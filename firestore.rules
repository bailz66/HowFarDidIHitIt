rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /stats/global {
      // Any authenticated user can read the global counter
      allow read: if request.auth != null;
      // Only allow incrementing totalShots (not arbitrary writes)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalShots'])
        && request.resource.data.totalShots == resource.data.totalShots + 1;
      // Allow initial document creation with totalShots = 1
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['totalShots'])
        && request.resource.data.totalShots == 1;
    }
  }
}