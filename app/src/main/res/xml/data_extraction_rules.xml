<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude SharedPreferences from cloud backup (synced via Firestore) -->
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Allow everything for device-to-device transfer -->
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
